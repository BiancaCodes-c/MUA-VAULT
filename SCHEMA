-- MUA Vault database schema (SQLite)

PRAGMA foreign_keys = ON;

-- 1. USERS (MUA / Artists)
CREATE TABLE IF NOT EXISTS users (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    email TEXT NOT NULL UNIQUE,
    password_hash TEXT NOT NULL,
    role TEXT NOT NULL DEFAULT 'artist' CHECK (role IN ('admin', 'artist')),
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP
);

-- 2. CLIENTS
CREATE TABLE IF NOT EXISTS clients (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    full_name TEXT NOT NULL,
    phone TEXT,
    email TEXT,
    instagram_handle TEXT,
    skin_tone TEXT CHECK (skin_tone IN ('Fair', 'Light', 'Medium', 'Tan', 'Deep')),
    undertone TEXT CHECK (undertone IN ('Cool', 'Warm', 'Neutral', 'Olive')),
    skin_type TEXT CHECK (skin_type IN ('Oily', 'Dry', 'Combination', 'Sensitive', 'Normal')),
    allergies TEXT,
    sensitivity_notes TEXT,
    preferred_brands TEXT,
    notes TEXT,
    photo_url TEXT,
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP
);

CREATE UNIQUE INDEX IF NOT EXISTS idx_clients_email
ON clients (email)
WHERE email IS NOT NULL;

-- Keep updated_at fresh on every client update.
CREATE TRIGGER IF NOT EXISTS trg_clients_updated_at
AFTER UPDATE ON clients
FOR EACH ROW
BEGIN
    UPDATE clients
    SET updated_at = CURRENT_TIMESTAMP
    WHERE id = OLD.id;
END;

-- 3. CLIENT ALLERGIES (normalized)
CREATE TABLE IF NOT EXISTS client_allergies (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    client_id INTEGER NOT NULL,
    allergy_name TEXT NOT NULL,
    reaction_notes TEXT,
    severity TEXT CHECK (severity IN ('Mild', 'Moderate', 'Severe')),
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (client_id) REFERENCES clients (id) ON DELETE CASCADE,
    UNIQUE (client_id, allergy_name)
);

-- 5. MAKEUP LOOKS
CREATE TABLE IF NOT EXISTS makeup_looks (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    look_name TEXT NOT NULL,
    category TEXT,
    description TEXT,
    skin_tone_match TEXT,
    difficulty_level TEXT CHECK (difficulty_level IN ('Beginner', 'Intermediate', 'Advanced')),
    image_url TEXT,
    created_by INTEGER,
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (created_by) REFERENCES users (id) ON DELETE SET NULL
);

-- 4. APPOINTMENTS
CREATE TABLE IF NOT EXISTS appointments (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    client_id INTEGER NOT NULL,
    look_id INTEGER,
    production_id INTEGER,
    shoot_day_id INTEGER,
    appointment_date DATETIME NOT NULL,
    start_time TEXT,
    end_time TEXT,
    event_type TEXT,
    location TEXT,
    status TEXT NOT NULL DEFAULT 'Booked' CHECK (status IN ('Booked', 'Completed', 'Cancelled')),
    price NUMERIC CHECK (price IS NULL OR price >= 0),
    deposit_paid INTEGER NOT NULL DEFAULT 0 CHECK (deposit_paid IN (0, 1)),
    deposit_amount NUMERIC CHECK (deposit_amount IS NULL OR deposit_amount >= 0),
    notes TEXT,
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (client_id) REFERENCES clients (id) ON DELETE CASCADE,
    FOREIGN KEY (look_id) REFERENCES makeup_looks (id) ON DELETE SET NULL,
    FOREIGN KEY (production_id) REFERENCES productions (id) ON DELETE SET NULL,
    FOREIGN KEY (shoot_day_id) REFERENCES shoot_days (id) ON DELETE SET NULL,
    CHECK (start_time IS NULL OR end_time IS NULL OR start_time <= end_time),
    CHECK (deposit_amount IS NULL OR price IS NULL OR deposit_amount <= price)
);

-- 6. PRODUCTS
CREATE TABLE IF NOT EXISTS products (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    brand TEXT NOT NULL,
    category TEXT NOT NULL CHECK (
        category IN (
            'Foundation', 'Concealer', 'Eyeshadow', 'Lipstick',
            'Lipgloss', 'Blush', 'Bronzer', 'Highlighter', 'Primer', 'Setting Spray',
            'Powder', 'Moisturizer'
        )
    ),
    shade TEXT,
    finish TEXT CHECK (finish IN ('Matte', 'Dewy', 'Satin', 'Glossy', 'Shimmer')),
    suitable_skin_type TEXT,
    expiration_date DATE,
    notes TEXT,
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP
);

CREATE INDEX IF NOT EXISTS idx_products_category ON products (category);

-- 7. LOOK ↔ PRODUCTS (many-to-many)
CREATE TABLE IF NOT EXISTS look_products (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    look_id INTEGER NOT NULL,
    product_id INTEGER NOT NULL,
    usage_notes TEXT,
    FOREIGN KEY (look_id) REFERENCES makeup_looks (id) ON DELETE CASCADE,
    FOREIGN KEY (product_id) REFERENCES products (id) ON DELETE CASCADE,
    UNIQUE (look_id, product_id)
);

-- 8. APPOINTMENT PRODUCTS (what was used)
CREATE TABLE IF NOT EXISTS appointment_products (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    appointment_id INTEGER NOT NULL,
    product_id INTEGER NOT NULL,
    quantity_used TEXT,
    FOREIGN KEY (appointment_id) REFERENCES appointments (id) ON DELETE CASCADE,
    FOREIGN KEY (product_id) REFERENCES products (id) ON DELETE RESTRICT,
    UNIQUE (appointment_id, product_id)
);

-- 9. CLIENT HISTORY
CREATE TABLE IF NOT EXISTS client_history (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    client_id INTEGER NOT NULL,
    appointment_id INTEGER,
    look_id INTEGER,
    date DATE,
    notes TEXT,
    client_feedback TEXT,
    would_recommend INTEGER CHECK (would_recommend IN (0, 1)),
    FOREIGN KEY (client_id) REFERENCES clients (id) ON DELETE CASCADE,
    FOREIGN KEY (appointment_id) REFERENCES appointments (id) ON DELETE SET NULL,
    FOREIGN KEY (look_id) REFERENCES makeup_looks (id) ON DELETE SET NULL,
    UNIQUE (appointment_id)
);

-- 10. FOUNDATION SHADES
CREATE TABLE IF NOT EXISTS foundation_shades (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    client_id INTEGER NOT NULL,
    brand TEXT NOT NULL,
    shade_name TEXT NOT NULL,
    shade_code TEXT,
    undertone TEXT CHECK (undertone IN ('Cool', 'Warm', 'Neutral', 'Olive')),
    notes TEXT,
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (client_id) REFERENCES clients (id) ON DELETE CASCADE,
    UNIQUE (client_id, brand, shade_name, shade_code)
);

-- 11. EYESHADOW PREFERENCES
CREATE TABLE IF NOT EXISTS eyeshadow_preferences (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    client_id INTEGER NOT NULL UNIQUE,
    finish_preference TEXT CHECK (finish_preference IN ('Matte', 'Shimmer', 'Glitter', 'Satin')),
    color_preference TEXT,
    notes TEXT,
    FOREIGN KEY (client_id) REFERENCES clients (id) ON DELETE CASCADE
);

-- 12. LIP PRODUCT PREFERENCES
CREATE TABLE IF NOT EXISTS lip_preferences (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    client_id INTEGER NOT NULL UNIQUE,
    lipstick_finish TEXT CHECK (lipstick_finish IN ('Matte', 'Satin', 'Glossy', 'Liquid')),
    lip_color_preference TEXT,
    lipgloss_preference INTEGER CHECK (lipgloss_preference IN (0, 1)),
    notes TEXT,
    FOREIGN KEY (client_id) REFERENCES clients (id) ON DELETE CASCADE
);

-- 13. BEFORE & AFTER PHOTOS
CREATE TABLE IF NOT EXISTS before_after_photos (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    appointment_id INTEGER NOT NULL,
    image_type TEXT NOT NULL CHECK (image_type IN ('Before', 'After')),
    image_url TEXT NOT NULL,
    notes TEXT,
    FOREIGN KEY (appointment_id) REFERENCES appointments (id) ON DELETE CASCADE,
    UNIQUE (appointment_id, image_type)
);

-- Helpful foreign-key indexes for faster joins.
CREATE INDEX IF NOT EXISTS idx_client_allergies_client_id ON client_allergies (client_id);
CREATE INDEX IF NOT EXISTS idx_appointments_client_id ON appointments (client_id);
CREATE INDEX IF NOT EXISTS idx_appointments_look_id ON appointments (look_id);
CREATE INDEX IF NOT EXISTS idx_appointments_production_id ON appointments (production_id);
CREATE INDEX IF NOT EXISTS idx_appointments_shoot_day_id ON appointments (shoot_day_id);
CREATE INDEX IF NOT EXISTS idx_makeup_looks_created_by ON makeup_looks (created_by);
CREATE INDEX IF NOT EXISTS idx_look_products_look_id ON look_products (look_id);
CREATE INDEX IF NOT EXISTS idx_look_products_product_id ON look_products (product_id);
CREATE INDEX IF NOT EXISTS idx_appointment_products_appointment_id ON appointment_products (appointment_id);
CREATE INDEX IF NOT EXISTS idx_appointment_products_product_id ON appointment_products (product_id);
CREATE INDEX IF NOT EXISTS idx_client_history_client_id ON client_history (client_id);
CREATE INDEX IF NOT EXISTS idx_foundation_shades_client_id ON foundation_shades (client_id);
CREATE INDEX IF NOT EXISTS idx_before_after_photos_appointment_id ON before_after_photos (appointment_id);

-- 14. PRODUCTIONS
CREATE TABLE IF NOT EXISTS productions (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    production_name TEXT NOT NULL,
    production_type TEXT NOT NULL CHECK (
        production_type IN (
            'Film',
            'TV Show',
            'Commercial',
            'Photoshoot',
            'Theater',
            'Music Video',
            'Editorial'
        )
    ),
    director_name TEXT,
    producer_name TEXT,
    start_date DATE,
    end_date DATE,
    location TEXT,
    notes TEXT,
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CHECK (end_date IS NULL OR start_date IS NULL OR end_date >= start_date)
);

-- 15. SHOOT DAYS / CALL WINDOWS
CREATE TABLE IF NOT EXISTS shoot_days (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    production_id INTEGER NOT NULL,
    shoot_date DATE NOT NULL,
    call_time TEXT,
    wrap_time TEXT,
    int_ext TEXT CHECK (int_ext IN ('Interior', 'Exterior')),
    shoot_type TEXT NOT NULL CHECK (shoot_type IN ('Photoshoot', 'Film', 'Theater')),
    location TEXT,
    weather_notes TEXT,
    scene_summary TEXT,
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (production_id) REFERENCES productions (id) ON DELETE CASCADE,
    CHECK (call_time IS NULL OR wrap_time IS NULL OR call_time <= wrap_time)
);

-- 16. CALL SHEETS
CREATE TABLE IF NOT EXISTS call_sheets (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    shoot_day_id INTEGER NOT NULL UNIQUE,
    call_sheet_file TEXT,
    crew_call_time TEXT,
    talent_call_time TEXT,
    notes TEXT,
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (shoot_day_id) REFERENCES shoot_days (id) ON DELETE CASCADE
);

-- 17. SCRIPT SIDES
CREATE TABLE IF NOT EXISTS script_sides (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    production_id INTEGER NOT NULL,
    shoot_day_id INTEGER,
    scene_number TEXT,
    page_number TEXT,
    script_file_url TEXT,
    sides_file_url TEXT,
    script_excerpt TEXT,
    continuity_notes TEXT,
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (production_id) REFERENCES productions (id) ON DELETE CASCADE,
    FOREIGN KEY (shoot_day_id) REFERENCES shoot_days (id) ON DELETE SET NULL
);

-- 18. CHARACTER MAKEUP TRACKING
CREATE TABLE IF NOT EXISTS character_makeup (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    production_id INTEGER NOT NULL,
    character_name TEXT NOT NULL,
    actor_name TEXT,
    makeup_description TEXT,
    fx_makeup INTEGER NOT NULL DEFAULT 0 CHECK (fx_makeup IN (0, 1)),
    continuity_notes TEXT,
    reference_photo TEXT,
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (production_id) REFERENCES productions (id) ON DELETE CASCADE,
    UNIQUE (production_id, character_name)
);

-- 19. SPECIAL EFFECTS MAKEUP
CREATE TABLE IF NOT EXISTS effects_makeup (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    character_id INTEGER NOT NULL,
    effect_type TEXT NOT NULL CHECK (
        effect_type IN (
            'Bruise',
            'Cut',
            'Burn',
            'Zombie',
            'Old Age',
            'Fantasy',
            'Prosthetic'
        )
    ),
    materials_used TEXT,
    application_time_minutes INTEGER CHECK (
        application_time_minutes IS NULL OR application_time_minutes >= 0
    ),
    removal_notes TEXT,
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (character_id) REFERENCES character_makeup (id) ON DELETE CASCADE
);

-- 20. LIGHTING CONDITIONS
CREATE TABLE IF NOT EXISTS lighting_conditions (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    shoot_day_id INTEGER NOT NULL,
    lighting_type TEXT NOT NULL CHECK (
        lighting_type IN (
            'Natural',
            'Studio',
            'Softbox',
            'LED',
            'Warm',
            'Cool',
            'Harsh'
        )
    ),
    lighting_notes TEXT,
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (shoot_day_id) REFERENCES shoot_days (id) ON DELETE CASCADE
);

-- 21. CONTINUITY PHOTOS
CREATE TABLE IF NOT EXISTS continuity_photos (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    character_id INTEGER NOT NULL,
    shoot_day_id INTEGER NOT NULL,
    image_url TEXT NOT NULL,
    angle_notes TEXT,
    makeup_notes TEXT,
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (character_id) REFERENCES character_makeup (id) ON DELETE CASCADE,
    FOREIGN KEY (shoot_day_id) REFERENCES shoot_days (id) ON DELETE CASCADE
);

-- Production panel indexes.
CREATE INDEX IF NOT EXISTS idx_shoot_days_production_id ON shoot_days (production_id);
CREATE INDEX IF NOT EXISTS idx_shoot_days_shoot_date ON shoot_days (shoot_date);
CREATE INDEX IF NOT EXISTS idx_script_sides_production_id ON script_sides (production_id);
CREATE INDEX IF NOT EXISTS idx_script_sides_shoot_day_id ON script_sides (shoot_day_id);
CREATE INDEX IF NOT EXISTS idx_character_makeup_production_id ON character_makeup (production_id);
CREATE INDEX IF NOT EXISTS idx_effects_makeup_character_id ON effects_makeup (character_id);
CREATE INDEX IF NOT EXISTS idx_lighting_conditions_shoot_day_id ON lighting_conditions (shoot_day_id);
CREATE INDEX IF NOT EXISTS idx_continuity_photos_character_id ON continuity_photos (character_id);
CREATE INDEX IF NOT EXISTS idx_continuity_photos_shoot_day_id ON continuity_photos (shoot_day_id);

-- 22. UPLOADS (global file storage registry)
CREATE TABLE IF NOT EXISTS uploads (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    uploaded_by INTEGER,
    original_filename TEXT NOT NULL,
    mime_type TEXT,
    file_size_bytes INTEGER CHECK (file_size_bytes IS NULL OR file_size_bytes >= 0),
    storage_url TEXT NOT NULL,
    checksum_sha256 TEXT,
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (uploaded_by) REFERENCES users (id) ON DELETE SET NULL
);

-- 23. UPLOAD LINKS (attach any file to any input field/entity)
CREATE TABLE IF NOT EXISTS upload_links (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    upload_id INTEGER NOT NULL,
    entity_type TEXT NOT NULL CHECK (
        entity_type IN (
            'clients',
            'products',
            'appointments',
            'before_after_photos',
            'productions',
            'shoot_days',
            'call_sheets',
            'script_sides',
            'character_makeup',
            'effects_makeup',
            'lighting_conditions',
            'continuity_photos'
        )
    ),
    entity_id INTEGER NOT NULL,
    field_name TEXT NOT NULL,
    is_primary INTEGER NOT NULL DEFAULT 0 CHECK (is_primary IN (0, 1)),
    notes TEXT,
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (upload_id) REFERENCES uploads (id) ON DELETE CASCADE,
    UNIQUE (upload_id, entity_type, entity_id, field_name)
);

CREATE INDEX IF NOT EXISTS idx_uploads_uploaded_by ON uploads (uploaded_by);
CREATE INDEX IF NOT EXISTS idx_upload_links_entity ON upload_links (entity_type, entity_id);
CREATE INDEX IF NOT EXISTS idx_upload_links_upload_id ON upload_links (upload_id);

-- 24. LOOKS MORGUE (visual look book)
CREATE TABLE IF NOT EXISTS looks_morgue (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    look_name TEXT NOT NULL,
    category TEXT,
    difficulty TEXT CHECK (difficulty IN ('Beginner', 'Intermediate', 'Pro')),
    skin_tone_tags TEXT CHECK (skin_tone_tags IS NULL OR json_valid(skin_tone_tags)),
    occasion_tags TEXT CHECK (occasion_tags IS NULL OR json_valid(occasion_tags)),
    image_url TEXT NOT NULL,
    gallery_urls TEXT CHECK (gallery_urls IS NULL OR json_valid(gallery_urls)),
    products_used TEXT CHECK (products_used IS NULL OR json_valid(products_used)),
    color_palette TEXT CHECK (color_palette IS NULL OR json_valid(color_palette)),
    created_by TEXT NOT NULL DEFAULT 'MUA Vault Team',
    created_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP
);

-- 25. LOOK MORGUE ASSIGNMENTS (for client planning)
CREATE TABLE IF NOT EXISTS look_morgue_assignments (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    look_morgue_id INTEGER NOT NULL,
    client_id INTEGER NOT NULL,
    assigned_by INTEGER,
    notes TEXT,
    assigned_at DATETIME NOT NULL DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (look_morgue_id) REFERENCES looks_morgue (id) ON DELETE CASCADE,
    FOREIGN KEY (client_id) REFERENCES clients (id) ON DELETE CASCADE,
    FOREIGN KEY (assigned_by) REFERENCES users (id) ON DELETE SET NULL
);

CREATE INDEX IF NOT EXISTS idx_looks_morgue_category ON looks_morgue (category);
CREATE INDEX IF NOT EXISTS idx_looks_morgue_difficulty ON looks_morgue (difficulty);
CREATE INDEX IF NOT EXISTS idx_look_morgue_assignments_client_id ON look_morgue_assignments (client_id);
CREATE INDEX IF NOT EXISTS idx_look_morgue_assignments_look_id ON look_morgue_assignments (look_morgue_id);

-- 24. UPLOAD DASHBOARD VIEW (all uploads with production-day context)
CREATE VIEW IF NOT EXISTS v_uploads_by_production_day AS
SELECT
    ul.id AS upload_link_id,
    u.id AS upload_id,
    ul.entity_type,
    ul.entity_id,
    ul.field_name,
    ul.is_primary,
    ul.notes AS link_notes,
    u.original_filename,
    u.mime_type,
    u.file_size_bytes,
    u.storage_url,
    u.checksum_sha256,
    u.created_at AS uploaded_at,
    usr.id AS uploaded_by_user_id,
    usr.name AS uploaded_by_name,
    COALESCE(
        p_prod.id,
        p_sd.id,
        p_cs.id,
        p_ss.id,
        p_cm.id,
        p_em.id,
        p_lc.id,
        p_cp.id,
        p_ap.id,
        p_bap.id
    ) AS production_id,
    COALESCE(
        p_prod.production_name,
        p_sd.production_name,
        p_cs.production_name,
        p_ss.production_name,
        p_cm.production_name,
        p_em.production_name,
        p_lc.production_name,
        p_cp.production_name,
        p_ap.production_name,
        p_bap.production_name
    ) AS production_name,
    COALESCE(
        sd.id,
        sd_cs.id,
        sd_ss.id,
        sd_lc.id,
        sd_cp.id,
        sd_ap.id,
        sd_bap.id
    ) AS shoot_day_id,
    COALESCE(
        sd.shoot_date,
        sd_cs.shoot_date,
        sd_ss.shoot_date,
        sd_lc.shoot_date,
        sd_cp.shoot_date,
        sd_ap.shoot_date,
        sd_bap.shoot_date
    ) AS shoot_date,
    CASE
        WHEN ul.entity_type = 'script_sides' THEN COALESCE(ss.scene_number, '')
        WHEN ul.entity_type = 'character_makeup' THEN COALESCE(cm.character_name, '')
        WHEN ul.entity_type = 'effects_makeup' THEN COALESCE(cm_em.character_name, '')
        WHEN ul.entity_type = 'call_sheets' THEN 'Call Sheet'
        ELSE NULL
    END AS context_label
FROM upload_links ul
JOIN uploads u ON u.id = ul.upload_id
LEFT JOIN users usr ON usr.id = u.uploaded_by

LEFT JOIN productions p_prod
    ON ul.entity_type = 'productions' AND p_prod.id = ul.entity_id

LEFT JOIN shoot_days sd
    ON ul.entity_type = 'shoot_days' AND sd.id = ul.entity_id
LEFT JOIN productions p_sd ON p_sd.id = sd.production_id

LEFT JOIN call_sheets cs
    ON ul.entity_type = 'call_sheets' AND cs.id = ul.entity_id
LEFT JOIN shoot_days sd_cs ON sd_cs.id = cs.shoot_day_id
LEFT JOIN productions p_cs ON p_cs.id = sd_cs.production_id

LEFT JOIN script_sides ss
    ON ul.entity_type = 'script_sides' AND ss.id = ul.entity_id
LEFT JOIN shoot_days sd_ss ON sd_ss.id = ss.shoot_day_id
LEFT JOIN productions p_ss ON p_ss.id = ss.production_id

LEFT JOIN character_makeup cm
    ON ul.entity_type = 'character_makeup' AND cm.id = ul.entity_id
LEFT JOIN productions p_cm ON p_cm.id = cm.production_id

LEFT JOIN effects_makeup em
    ON ul.entity_type = 'effects_makeup' AND em.id = ul.entity_id
LEFT JOIN character_makeup cm_em ON cm_em.id = em.character_id
LEFT JOIN productions p_em ON p_em.id = cm_em.production_id

LEFT JOIN lighting_conditions lc
    ON ul.entity_type = 'lighting_conditions' AND lc.id = ul.entity_id
LEFT JOIN shoot_days sd_lc ON sd_lc.id = lc.shoot_day_id
LEFT JOIN productions p_lc ON p_lc.id = sd_lc.production_id

LEFT JOIN continuity_photos cp
    ON ul.entity_type = 'continuity_photos' AND cp.id = ul.entity_id
LEFT JOIN shoot_days sd_cp ON sd_cp.id = cp.shoot_day_id
LEFT JOIN character_makeup cm_cp ON cm_cp.id = cp.character_id
LEFT JOIN productions p_cp ON p_cp.id = COALESCE(cm_cp.production_id, sd_cp.production_id)

LEFT JOIN appointments ap
    ON ul.entity_type = 'appointments' AND ap.id = ul.entity_id
LEFT JOIN shoot_days sd_ap ON sd_ap.id = ap.shoot_day_id
LEFT JOIN productions p_ap ON p_ap.id = COALESCE(ap.production_id, sd_ap.production_id)

LEFT JOIN before_after_photos bap
    ON ul.entity_type = 'before_after_photos' AND bap.id = ul.entity_id
LEFT JOIN appointments ap_bap ON ap_bap.id = bap.appointment_id
LEFT JOIN shoot_days sd_bap ON sd_bap.id = ap_bap.shoot_day_id
LEFT JOIN productions p_bap ON p_bap.id = COALESCE(ap_bap.production_id, sd_bap.production_id);
